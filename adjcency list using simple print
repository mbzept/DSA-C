#include <stdio.h>
#include <stdlib.h>

struct Node{
    int data;
    struct Node *next;
};
struct List{
    struct Node *head;
};
struct List *adjList[5];
void addNode(int s,int d){
    struct Node *newNode=(struct Node *)malloc(sizeof(struct Node));
    newNode->data=d;
    newNode->next=NULL;
    if (adjList[s]->head==NULL){
        adjList[s]->head=newNode;
    }
    else{
        struct Node *temp=adjList[s]->head;
        while(temp->next!=NULL){
            temp=temp->next;
        }
        temp->next=newNode;
    }
}
void addEdge(int u, int v){
    addNode(u,v);
    addNode(u,v);
}
void printEdge(){
    for (int i=0;i<5;i++){
        printf("\n AdjList of %d:",i);
        struct Node *temp=adjList[i]->head;
        while(temp!=NULL){
            printf("%d->",temp->data);
            temp=temp->next;
        }
        printf("NULL");
    }
}
int main() {
    for (int i=0; i<5;i++){
        adjList[i]=(struct List *)malloc(sizeof(struct List));
        adjList[i]->head=NULL;
    }
    addEdge(0,1);
    addEdge(0,2);
    addEdge(2,3);
    addEdge(3,1);
    addEdge(4,1);
    printEdge();
}
